{
    "configurations": [
        {
            "type": "command",
            "name": "Config",
            "program": "cmake",
            "args": ["-B", "$PROJECT_DIR$/build/x64-debug", "-S", ".", "-G", "MinGW Makefiles", "-DCMAKE_BUILD_TYPE=Debug", "-DCMAKE_C_FLAGS=-m64", "-DCMAKE_CXX_FLAGS=-m64", "-DEXECUTABLE_OUTPUT_PATH=$PROJECT_DIR$/build/x64-debug/bin", "-DLIBRARY_OUTPUT_PATH=$PROJECT_DIR$/build/x64-debug/libs", "-DBUILD_SHARED_LIBS=OFF", "-DBUILD_STATIC_LIBS=ON", "-DCMAKE_C_COMPILER=x86_64-w64-mingw32-gcc.exe", "-DCMAKE_CXX_COMPILER=x86_64-w64-mingw32-g++.exe"]
